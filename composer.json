{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "he4rt/brainiac",
    "type": "project",
    "description": "",
    "keywords": [
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "alizharb/filament-activity-log": "^1.3.3",
        "basementdevs/filament-better-mails": "^5.2.0",
        "filament/filament": "^5.6.7",
        "filament/spatie-laravel-media-library-plugin": "^5.6.7",
        "guava/filament-knowledge-base": "^3.1.0",
        "he4rt/catalog": ">=1",
        "he4rt/identity": "^1.0.0",
        "he4rt/panel-admin": "^1.0.0",
        "he4rt/panel-portal": "^1.0",
        "internachi/modular": "^3.0.2",
        "joaopaulolndev/filament-edit-profile": "^3.0.2",
        "laravel/framework": "^13.18.0",
        "laravel/tinker": "^3.0.2",
        "league/flysystem-sftp-v3": "^3.33.0",
        "monicahq/laravel-cloudflare": "^4.1.0",
        "owenvoke/blade-fontawesome": "^3.3.0",
        "saloonphp/saloon": "^4.0.0",
        "spatie/laravel-activitylog": "^5.0.0",
        "spatie/laravel-backup": "^10.3.0",
        "spatie/laravel-permission": "^7.4.2",
        "stechstudio/filament-impersonate": "^5.5.0",
        "tpetry/laravel-postgresql-enhanced": "^3.7.0",
        "tpetry/laravel-query-expressions": "^1.6.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.5.0",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.3.0",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.11",
        "laravel/pail": "^1.2.7",
        "laravel/pao": "^1.1.2",
        "laravel/pint": "^1.29.3",
        "laravel/telescope": "^5.20.0",
        "mockery/mockery": "^1.6.12",
        "mrpunyapal/rector-pest": "^0.2.15",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.4",
        "pestphp/pest-plugin-faker": "^4.0.0",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-livewire": "^4.1.0",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.2.3",
        "rector/rector": "^2.5.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "bun install",
            "composer run-script post-root-package-install",
            "composer run-script post-create-project-cmd",
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --ansi",
            "@php artisan modules:sync --no-phpunit --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite"
        ],
        "pint": "vendor/bin/pint --parallel",
        "test:pint": "vendor/bin/pint --test --parallel",
        "rector": "vendor/bin/rector",
        "test:rector": "vendor/bin/rector --dry-run",
        "phpstan": "vendor/bin/phpstan analyse --ansi",
        "test:phpstan": "vendor/bin/phpstan analyse --ansi",
        "test:unit": "vendor/bin/pest --compact --group=unit",
        "test:feature": "vendor/bin/pest --compact --group=feature",
        "test:browser": "vendor/bin/pest --compact --group=browser",
        "test:cov": "vendor/bin/pest --compact --coverage",
        "check": [
            "@test:rector",
            "@test:pint",
            "@test:phpstan"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "vendor/bin/pest --compact"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan modules:sync --no-phpunit --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-debugbar",
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "bump-after-update": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "audit": {
            "abandoned": "report",
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "app-modules/*",
            "options": {
                "symlink": true
            }
        }
    ]
}
