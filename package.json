{
    "name": "@he4rt/brainiac",
    "license": "MIT",
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"**/*.{js,ts,json,yml,md,css}\"",
        "prepare": "husky",
        "outdated": "npm-check-updates"
    },
    "devDependencies": {
        "@tailwindcss/typography": "0.5.20",
        "@tailwindcss/vite": "4.3.1",
        "autoprefixer": "10.5.2",
        "concurrently": "10.0.3",
        "husky": "9.1.7",
        "laravel-vite-plugin": "3.1.0",
        "lint-staged": "17.0.8",
        "npm-check-updates": "22.2.7",
        "prettier": "3.9.0",
        "tailwindcss": "4.3.1",
        "vite": "8.1.0"
    },
    "lint-staged": {
        "*.{js,ts,json,yml,md,css,blade.php}": [
            "prettier --write"
        ],
        "*.php": [
            "vendor/bin/rector process",
            "vendor/bin/pint"
        ]
    }
}
